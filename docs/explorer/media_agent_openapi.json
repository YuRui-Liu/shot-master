  "components": {
    "schemas": {
      "AspectModel": {
        "properties": {
          "w": {
            "type": "integer",
            "title": "W",
            "default": 0
          },
          "h": {
            "type": "integer",
            "title": "H",
            "default": 0
          }
        },
        "type": "object",
        "title": "AspectModel"
      },
      "BatchGenRequest": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/GenRequest"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "BatchGenRequest"
      },
      "BatchGenerateRequest": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/GenerateBgmRequest"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "BatchGenerateRequest"
      },
      "BatchSplitRequest": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/SplitRequest"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "BatchSplitRequest"
      },
      "CellBoxesRequest": {
        "properties": {
          "src_path": {
            "type": "string",
            "title": "Src Path"
          },
          "n_rows": {
            "type": "integer",
            "title": "N Rows"
          },
          "n_cols": {
            "type": "integer",
            "title": "N Cols"
          },
          "white_threshold": {
            "type": "integer",
            "title": "White Threshold",
            "default": 240
          },
          "min_ratio": {
            "type": "number",
            "title": "Min Ratio",
            "default": 0.95
          }
        },
        "type": "object",
        "required": [
          "src_path",
          "n_rows",
          "n_cols"
        ],
        "title": "CellBoxesRequest"
      },
      "CombineRequest": {
        "properties": {
          "src_paths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Src Paths"
          },
          "target_rows": {
            "type": "integer",
            "title": "Target Rows"
          },
          "target_cols": {
            "type": "integer",
            "title": "Target Cols"
          },
          "gap": {
            "type": "integer",
            "title": "Gap",
            "default": 0
          },
          "target_aspect": {
            "$ref": "#/components/schemas/AspectModel",
            "default": {
              "w": 0,
              "h": 0
            }
          },
          "scale_mode": {
            "type": "string",
            "title": "Scale Mode",
            "default": "letterbox"
          },
          "out_path": {
            "type": "string",
            "title": "Out Path"
          },
          "fmt": {
            "type": "string",
            "title": "Fmt",
            "default": "PNG"
          }
        },
        "type": "object",
        "required": [
          "src_paths",
          "target_rows",
          "target_cols",
          "out_path"
        ],
        "title": "CombineRequest"
      },
      "ComposePromptRequest": {
        "properties": {
          "global_style": {
            "type": "string",
            "title": "Global Style"
          },
          "emotion": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EmotionIn"
              },
              {
                "type": "null"
              }
            ]
          },
          "duration": {
            "type": "number",
            "title": "Duration"
          },
          "fade_out": {
            "type": "boolean",
            "title": "Fade Out",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "global_style",
          "duration"
        ],
        "title": "ComposePromptRequest"
      },
      "CompositionRequest": {
        "properties": {
          "composition": {
            "additionalProperties": true,
            "type": "object",
            "title": "Composition"
          }
        },
        "type": "object",
        "required": [
          "composition"
        ],
        "title": "CompositionRequest"
      },
      "CropAspectRequest": {
        "properties": {
          "src_path": {
            "type": "string",
            "title": "Src Path"
          },
          "aspect": {
            "$ref": "#/components/schemas/AspectModel"
          },
          "out_path": {
            "type": "string",
            "title": "Out Path"
          },
          "fmt": {
            "type": "string",
            "title": "Fmt",
            "default": "PNG"
          }
        },
        "type": "object",
        "required": [
          "src_path",
          "aspect",
          "out_path"
        ],
        "title": "CropAspectRequest"
      },
      "DetectRequest": {
        "properties": {
          "src_path": {
            "type": "string",
            "title": "Src Path"
          },
          "white_threshold": {
            "type": "integer",
            "title": "White Threshold",
            "default": 240
          },
          "min_white_ratio": {
            "type": "number",
            "title": "Min White Ratio",
            "default": 0.95
          }
        },
        "type": "object",
        "required": [
          "src_path"
        ],
        "title": "DetectRequest"
      },
      "EmotionIn": {
        "properties": {
          "labels": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Labels",
            "default": []
          },
          "valence": {
            "type": "number",
            "title": "Valence",
            "default": 0.0
          },
          "arousal": {
            "type": "number",
            "title": "Arousal",
            "default": 0.0
          },
          "intensity": {
            "type": "number",
            "title": "Intensity",
            "default": 0.5
          }
        },
        "type": "object",
        "title": "EmotionIn"
      },
      "GenRequest": {
        "properties": {
          "prompt": {
            "type": "string",
            "title": "Prompt"
          },
          "references": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "References",
            "default": []
          },
          "size": {
            "type": "string",
            "title": "Size",
            "default": "1024x1024"
          },
          "n": {
            "type": "integer",
            "title": "N",
            "default": 1
          },
          "out_dir": {
            "type": "string",
            "title": "Out Dir"
          },
          "base_name": {
            "type": "string",
            "title": "Base Name",
            "default": "img"
          },
          "ext": {
            "type": "string",
            "title": "Ext",
            "default": "png"
          }
        },
        "type": "object",
        "required": [
          "prompt",
          "out_dir"
        ],
        "title": "GenRequest"
      },
      "GenerateBgmRequest": {
        "properties": {
          "workflow_id": {
            "type": "string",
            "title": "Workflow Id"
          },
          "out_dir": {
            "type": "string",
            "title": "Out Dir"
          },
          "seeds": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Seeds",
            "default": [
              1,
              2
            ]
          },
          "tags": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tags"
          },
          "bpm": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bpm"
          },
          "duration": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration"
          },
          "global_style": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Global Style"
          },
          "emotion": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EmotionIn"
              },
              {
                "type": "null"
              }
            ]
          },
          "fade_out": {
            "type": "boolean",
            "title": "Fade Out",
            "default": false
          },
          "timeout": {
            "type": "number",
            "title": "Timeout",
            "default": 600.0
          },
          "poll_interval": {
            "type": "number",
            "title": "Poll Interval",
            "default": 5.0
          }
        },
        "type": "object",
        "required": [
          "workflow_id",
          "out_dir"
        ],
        "title": "GenerateBgmRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MarginsModel": {
        "properties": {
          "top": {
            "type": "integer",
            "title": "Top",
            "default": 0
          },
          "right": {
            "type": "integer",
            "title": "Right",
            "default": 0
          },
          "bottom": {
            "type": "integer",
            "title": "Bottom",
            "default": 0
          },
          "left": {
            "type": "integer",
            "title": "Left",
            "default": 0
          }
        },
        "type": "object",
        "title": "MarginsModel"
      },
      "RenderRequest": {
        "properties": {
          "composition": {
            "additionalProperties": true,
            "type": "object",
            "title": "Composition"
