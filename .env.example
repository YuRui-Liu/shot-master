# === 默认后端 ===
# 默认用豆包视觉理解（兼容 OpenAI Chat Completions API）
# 切到其它后端：gemini / anthropic / qwen / openai / deepseek / openrouter / siliconflow / vllm
DEFAULT_PROVIDER=doubao
DEFAULT_MODEL=doubao-seed-2-0-pro-260215

# 豆包 ARK 兼容字段：如果你只在 .env 设了 ARK_API_KEY（豆包官方示例的环境变量名），
# 请同步设到下面的 DOUBAO_API_KEY；本程序读 DOUBAO_API_KEY 不读 ARK_API_KEY。

# === Gemini ===
GEMINI_API_KEY=
GEMINI_BASE_URL=

# === OpenAI 兼容（每个 endpoint 一组 key + base_url）===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
VLLM_API_KEY=EMPTY
VLLM_BASE_URL=http://127.0.0.1:8000/v1

# === Anthropic ===
ANTHROPIC_API_KEY=

# === Qwen-VL (DashScope) ===
DASHSCOPE_API_KEY=

# === 输出 ===
DEFAULT_OUTPUT_DIR=

# === 服务 ===
HOST=127.0.0.1
PORT=7866

# === RunningHub（远端 SaaS，用于 LTX 视频生成）===
RUNNINGHUB_API_KEY=
RUNNINGHUB_BASE_URL=https://www.runninghub.cn
